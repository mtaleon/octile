{
  "name": "octile",
  "version": "2.0.0",
  "description": "Octile puzzle game",
  "author": "Octile",
  "main": "main.js",
  "private": true,
  "repository": "github:mtaleon/octile",
  "scripts": {
    "dev": "electron .",
    "build:web": "cd .. && ./scripts/build.sh",
    "build:win": "npm run build:web && electron-builder --win",
    "build:mac": "npm run build:web && electron-builder --mac",
    "build:linux": "npm run build:web && electron-builder --linux",
    "build:all": "npm run build:web && electron-builder --win --mac --linux"
  },
  "dependencies": {
    "steamworks.js": "^0.3.1"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "cc.eu.octile.game",
    "productName": "Octile",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "steam_appid.txt"
    ],
    "extraResources": [
      {
        "from": "../dist/web",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../icons/octile.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
}
